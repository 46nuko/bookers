<h1>Books</h1>
<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Body</th>
      <th colspan="3"></th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <% @books.each do |book| %>
        <td>
          <span><%= book.title %></span>
        </td>
        <td>
          <span><%= book.body %></span>
        </td>
        <td>
          <span>
            <%= link_to "Show" , book_path(book.id) %>
          </span>
        </td>
        <td>
          <span>
            <%= link_to "Edit", edit_book_path(book.id) %>
          </span>
        </td>
        <td>
          <span>
            <%= link_to "Destroy", book_path(book.id),  data: { turbo_method: :delete, turbo_confirm: "Are you sure ?" } %>
          </span>
        </td>
      <% end %>
    </tr>
  </tbody>
</table>
<h2>New book</h2>
<%= form_with model: Book.new do |f| %>
  <h4>タイトル</h4>
  <%= f.text_field :title %>
	
  <h4>本文</h4>
  <%= f.text_area :body %>
	
  <%= f.submit '投稿' %>
<% end %>