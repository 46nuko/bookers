<h1>Books</h1>
<table>
  <tr>
    <th>Title</th>
    <th>Body</th>
    <th colspan="3"></th>
  </tr>
  
  <% @books.each do |book| %>
    <tr>

      <td>
        <span><%= book.title %></span>
      </td>

      <td>
        <span><%= book.body %></span>
      </td>

      <td>
        <span>
          <%= link_to "Show" , book_path(book.id), class: "show_link" %>
        </span>
      </td>

      <td>
        <span>
          <%= link_to "Edit", edit_book_path(book.id), class: "edit_link" %>
        </span>
      </td>

      <td>
        <span>
          <%= link_to "Destroy", book_path(book.id), class: "destroy-link", data: { turbo_method: :delete, turbo_confirm: "Are you sure ?" } %>
        </span>
      </td>

    </tr>
  <% end %>

</table>

<h2>New book</h2>

<% if @book.errors.any? %>
  <div class="error-message">
    <%= @book.errors.count %>errors prohibited this book from being saved:
      <ul>
        <% @book.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
  </div>
<% end %>

<%= form_with model: Book.new, id: 'new_book', html:{ class: 'new_book' } do |f| %>

  <div class="field">
    <label>Title</label>
    <%= f.text_field :title, class: 'book_title' %>
	</div>

  <div class="field">
    <label>Body</label>
    <%= f.text_area :body, class: 'book_body' %>
	</div>

  <div class="action">
    <%= f.submit 'Create Book' %>
  </div>
  
<% end %>